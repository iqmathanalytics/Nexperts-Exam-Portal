PORT=3001
NODE_ENV=development

# Comma-separated browser origins allowed in production (Netlify URL + previews)
CLIENT_URL=http://localhost:8080
CLIENT_URLS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080

DATABASE_URL=mysql://user:password@host:4000/db?sslaccept=strict

JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Nexperts Academy

ADMIN_EMAIL=admin@nexperts.io
ADMIN_PASSWORD=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8080/payment-success
STRIPE_CANCEL_URL=http://localhost:8080/dashboard/exams

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

PROCTORING_SERVICE_URL=http://127.0.0.1:8765

# Invoice / certificate issuer (shown on PDFs)
INVOICE_COMPANY_NAME=Nexperts Academy
INVOICE_COMPANY_LEGAL_NAME=Nexperts Academy Sdn. Bhd.
INVOICE_COMPANY_ADDRESS=Level 10, Menara XYZ|Jalan Ampang|50450 Kuala Lumpur|Malaysia
INVOICE_COMPANY_EMAIL=billing@nexperts.io
INVOICE_COMPANY_PHONE=+60 3-1234 5678
INVOICE_COMPANY_WEBSITE=https://nexperts.io
INVOICE_COMPANY_TAX_ID=

# Production (Render): skip Puppeteer’s bundled Chromium download — use @sparticuz/chromium instead
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
